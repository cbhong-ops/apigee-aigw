<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="oauth2">
  <Description/>
  <FaultRules/>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>ADD-CORS</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows>
    <Flow name="AccessTokenCC">
      <Description/>
      <Request>
        <Step>
          <Name>OA2-AccessToken</Name>
        </Step>
      </Request>
      <Response/>
      <Condition>(proxy.pathsuffix MatchesPath "/accesstoken") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="RefreshToken">
      <Description/>
      <Request>
        <Step>
          <Name>OA2-RefreshToken</Name>
        </Step>
      </Request>
      <Response/>
      <Condition>(proxy.pathsuffix MatchesPath "/refreshtoken") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="InvalidateToken">
      <Description/>
      <Request>
        <Step>
          <Name>OA2-InvalidateToken</Name>
        </Step>
        <Step>
          <Name>AM-GetRequest</Name>
        </Step>
      </Request>
      <Response>
        <Step>
          <Name>AM-InvalidateTokenResponse</Name>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/invalidatetoken") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="RevokeToken">
      <Description/>
      <Request>
        <Step>
          <Name>ROA-RevokeToken</Name>
        </Step>
        <Step>
          <Name>AM-GetRequest</Name>
        </Step>
      </Request>
      <Response>
        <Step>
          <Name>AM-RevokeTokenResponse</Name>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/revoketoken") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="UnknownRequest">
      <Description/>
      <Request>
        <Step>
          <Name>RF-UnknownRequest</Name>
        </Step>
      </Request>
      <Response/>
    </Flow>
  </Flows>
  <HTTPProxyConnection>
    <BasePath>/v1/apigee-aigw/oauth2</BasePath>
    <Properties/>
  </HTTPProxyConnection>
  <RouteRule name="NoRouteRule"/>
</ProxyEndpoint>
