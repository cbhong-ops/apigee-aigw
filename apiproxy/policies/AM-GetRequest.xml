<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage continueOnError="false" enabled="true" name="AM-GetRequest">
  <DisplayName>AM-GetRequest</DisplayName>
  <Properties/>
  <AssignVariable>
    <Name>vd.accesstoken</Name>
    <Ref>request.formparam.token</Ref>
  </AssignVariable>
  <AssignVariable>
    <Name>vd.enduser_id</Name>
    <Ref>request.formparam.enduser_id</Ref>
  </AssignVariable>
  <Remove>
    <FormParams>
      <FormParam name="token"/>
      <FormParam name="enduser_id"/>
    </FormParams>
  </Remove>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
  <AssignTo createNew="false" transport="http" type="request"/>
</AssignMessage>
